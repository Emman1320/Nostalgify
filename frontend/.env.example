# Frontend Environment Variables

# Optional backend API URL override. Defaults to /api in production.
REACT_APP_BACKEND_URL=http://localhost:8000

# Optional WebSocket origin override. Defaults to the current page origin.
REACT_APP_WEB_SOCKET_URL=http://localhost:5000

# Optional Socket.IO path override. Defaults to /socket.io.
REACT_APP_WEB_SOCKET_PATH=/socket.io
