# Server Configuration
PORT=8000
SOCKET_PORT=5000
SOCKET_PATH=/socket.io

# Allowed browser origins, comma-separated
CORS_ORIGIN=http://localhost:3000

# Valkey/Redis Configuration
# Valkey is a Redis fork - fully compatible!
# For local development with default Valkey:
VALKEY_URL=redis://localhost:6379

# Also supports REDIS_URL for backwards compatibility:
# REDIS_URL=redis://localhost:6379

# For Valkey/Redis with password:
# VALKEY_URL=redis://:password@localhost:6379

# For Valkey/Redis Cloud or remote:
# VALKEY_URL=redis://username:password@host:port

# For Valkey/Redis with TLS:
# VALKEY_URL=rediss://username:password@host:port
